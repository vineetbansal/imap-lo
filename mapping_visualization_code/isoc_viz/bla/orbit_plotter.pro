                    [0.,1.,0.],[-sin(angle),0.,cos(angle)]]
        
        orbi = fltarr(3,360)
        orbi = (rotation # ESvec)
        ;pos1 = (rotation #pos1)    
        ;SCSunvec1 = (rotation #SCSunvec1)


        if keyword_set(HELIO) then begin     
            PLOT, Svec[0,*,*], Svec[1,*,*],COLOR=200
            make_nose, ESunvec1,/HELIO
            ;will probably change later
            length = 1e4
        endif
