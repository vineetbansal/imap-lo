pro plot_orbit3D, infle, outfle, HELIO=HELIO, MAG=MAG
                       
        Struct =reader(infle, outfle)
        n = where(Struct.jul1 eq (max(Struct.jul1)-min(Struct.jul1))/2.+min(Struct.jul1))

        set_plot, 'ps'
        device, /COLOR
        device, FILENAME=outfle
        loadct, 39

        angle = 5*!pi/180.
        rotation = [[cos(angle),0.,sin(angle)], $
                    [0.,1.,0.],[-sin(angle),0.,cos(angle)]]
        
        orbi = fltarr(3,360)
        orbi = (rotation # Struct.ESvec)


        if keyword_set(HELIO) then begin     
            SURFACE,DIST(5),/NODATA, /SAVE, TIT='TEST', $
              XRANGE=[min(Struct.ESvec[0,*]),max(Struct.ESvec[0,*])], $
              YRANGE=[min(Struct.ESvec[1,*]), max(Struct.ESvec[1,*])], $
              ZRANGE = [min(Struct.ESvec[0,*]),max(Struct.ESvec[0,*])]
            PLOTS, Struct.Svec[0,*,*], Struct.Svec[1,*,*], Struct.Svec[2,*,*],$
              COLOR=200, /T3D
            make_nose, Struct.ESunvec1,/HELIO
            ;will probably change later
            length = 1e4
        endif
        if not keyword_set(HELIO) then begin
            SURFACE,DIST(5),/NODATA, /SAVE, TIT='TEST', $
          XRANGE=[min(Struct.pos1[0,*]),max(Struct.pos1[0,*])], $
          YRANGE=[min(Struct.pos1[1,*]), max(Struct.pos1[1,*])], $
          ZRANGE = [min(Struct.pos1[2,*]),max(Struct.pos1[2,*])]
            make_nose, Struct.ESunvec1
            length = 1e4
        end 
        ;PLOTS, orbi[0,*], orbi[1,*], orbi[2,*], /T3D
        PLOTS, Struct.ESvec[0,*], Struct.ESvec[1,*],Struct.ESvec[2,*],/T3D
        PLOTS, Struct.pos1[0,*], Struct.pos1[1,*], Struct.pos1[2,*], /T3D
        PLOTS, Struct.pos1[0,n], Struct.pos1[1,n], Struct.pos1[2,n], PSYM = 2, COLOR =250, /T3D
        PLOTS, Struct.Evec[0,*,*], Struct.Evec[1,*,*], Struct.Evec[2,*,*], COLOR=60, /T3D
        
        tmpvec = fltarr(3,2)
        i = n_elements(Struct.jul1[0,*])
        for k=0, i-1 do begin
            tmpvec[0,0] = Struct.pos1[0,k] 
            tmpvec[1,0] = Struct.pos1[1,k]
            tmpvec[2,0] = Struct.pos1[2,k]
            tmpvec[0,1] = tmpvec[0,0] + Struct.SCSunvec1[0,k]*length
            tmpvec[1,1] = tmpvec[1,0] + Struct.SCSunvec1[1,k]*length
            tmpvec[2,1] = tmpvec[2,0] + Struct.SCSunvec1[2,k]*length
            PLOTS, tmpvec[0,*],tmpvec[1,*], tmpvec[2,*],/T3D
        endfor
        if keyword_set(MAG) then make_mag,Struct.ESunvec1[*,n]
        
        close, 1
    end






